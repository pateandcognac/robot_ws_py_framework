{
    "context": {
        "header_name": "prelude_context",
        "footer_name": "live_context",
        "show_header_stats": true,
        "show_footer_stats": true,
        "show_io_buffer_stats": true,
        "show_io_cell_stats": true,
        "show_snippet_ttl": true,
        "token_estimation_divisor": 5
    },
    "main_model": {
        "model": "gemini-flash-latest",
        "temperature": 0.7,
        "thinking_config": {
            "include_thoughts": true,
            "thinking_budget": -1
        },
        "stop_sequences": ["</me>", "<py_result>"]
    },
    "python": {
        "preload_api_files": ["core.py"],
        "default_timeout": 300
    },
    "agent_settings": {
        "global_max_io_buffer_media": 10
    }
}