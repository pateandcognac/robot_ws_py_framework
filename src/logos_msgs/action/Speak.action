# Goal: What Logos wants to say and how to say it
string utterance_text  # The full string with inline emoji, e.g., "Hello! 👋 I'm curious! 🤔"
string engine          # "kokoro" (default), piper, espeak. add festival later? what else!?
string engine_params   # JSON string of engine specific parameters, e.g. '{"voice": "am_onyx", "speed": 1.2}'
---
# Result: Outcome of the entire speech action
bool success             
string final_message     
float32 total_duration   
---
# Feedback: Progress updates on synthesis
int32 current_chunk_index 
int32 total_chunks        
string text_snippet       
string emoji_snippet      
float32 chunk_duration