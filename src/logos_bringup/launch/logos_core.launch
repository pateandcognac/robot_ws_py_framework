<launch>
  <!-- Arguments -->
  <arg name="base"       default="$(optenv TURTLEBOT_BASE kobuki)"/>
  <arg name="battery"    default="$(optenv TURTLEBOT_BATTERY /proc/acpi/battery/BAT0)"/>
  <arg name="stacks"     default="$(optenv TURTLEBOT_STACKS hexagons)"/>
  <arg name="3d_sensor"  default="$(optenv TURTLEBOT_3D_SENSOR astra)"/>

  <!-- 1. Robot Description (URDF/TF) -->
  <include file="$(find turtlebot_bringup)/launch/includes/robot.launch.xml">
    <arg name="base" value="$(arg base)" />
    <arg name="stacks" value="$(arg stacks)" />
    <arg name="3d_sensor" value="$(arg 3d_sensor)" />
  </include>

  <!-- 2. Logos Mobile Base (Motor, Mux, Smoother) -->
  <include file="$(find logos_bringup)/launch/includes/logos_mobile_base.launch.xml">
    <arg name="base" value="$(arg base)" />
  </include>

  <!-- 3. 3D Sensor (Astra) -->
  <!-- We use the standard TB2 launch, but we can add args here if we need to tweak processing -->
  <include file="$(find turtlebot_bringup)/launch/3dsensor.launch">
    <arg name="3d_sensor" value="$(arg 3d_sensor)"/>
    <arg name="scan_topic" value="scan"/>
  </include>

  <!-- 4. Battery Monitor (Optional but good to have) -->
  <include unless="$(eval arg('battery') == 'None')" file="$(find turtlebot_bringup)/launch/includes/netbook.launch.xml">
    <arg name="battery" value="$(arg battery)" />
  </include>

  <!-- 5. Hardware & Expression -->
  <!-- Includes Arduinos, Arms, and Expressive Logic -->
  <include file="$(find logos_hardware)/launch/logos_hardware.launch" />

  <!-- 6. Non-ROS TTS Server (Python 3.11) -->
  <!-- Interfaces with a Speak.action server -->
  <!-- We use the shell script wrapper to bridge ROS Noetic and the external venv -->
  <node pkg="logos_hardware" type="run_tts_server.sh" name="logos_tts_server" output="screen">

  </node>
  <!-- python3.11 venv script: ~/src/logos_tts_server$ /home/robot/src/logos_tts_server/.venv/bin/python /home/robot/src/logos_tts_server/server.py -->


  <!-- State Monitor (Battery/Charging/Idle anims) 
  <node name="idle_state_monitor" pkg="logos_hardware" type="idle_state_indicator.py" output="screen"/>
  -->



</launch>