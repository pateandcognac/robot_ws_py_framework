<launch>
  <!-- 
    LOGOS HARDWARE LAYER
    - Pan/Tilt (Arduino Mega)
    - Arms (Arduino Uno)
    - Arm Controllers
  -->

  <!-- 1. ARDUINO BRIDGES -->
  <!-- Pan-Tilt Control (Arduino Mega) -->
  <node name="pantilt_serial_node" pkg="rosserial_server" type="serial_node" output="screen">
    <param name="port" value="/dev/mega_duino"/> 
    <param name="baud" value="57600"/>
  </node>

  <!-- Arm Control (Arduino Uno) -->
  <node name="arm_serial_node" pkg="rosserial_server" type="serial_node" output="screen">
    <param name="port" value="/dev/uno_duino"/>
    <param name="baud" value="57600"/>
  </node>

  <!-- 2. EXPRESSIVE NODES (Python 3.8 System) -->
  
  <!-- Arm Logic -->
  <node name="arm_controller" pkg="logos_hardware" type="arm_controller_node.py" output="screen"/>


  <!-- 3. TTP (Text-to-Performance) -->
  <!-- The performance sequencer replaces the old audio_and_face_playback.py
       + arm_playback_node.py pair (single playback clock for all tracks).
       To revert, comment the sequencer and restore these two lines:
  <node name="arm_playback" pkg="logos_hardware" type="arm_playback_node.py" output="screen"/>
  <node name="tts_face_playback" pkg="logos_hardware" type="audio_and_face_playback.py" output="screen"/>
  -->

  <node name="tts_action_server" pkg="logos_hardware" type="tts_action_server.py" output="screen"/>
  <node name="performance_sequencer" pkg="logos_hardware" type="performance_sequencer_node.py" output="screen"/>

  <!-- Face Animator: tiny on-CPU LLM (via Ollama) that turns cue text/emoji
       into bespoke face tracks. Sequencer falls back to the LUT without it,
       so this node is safe to disable. Knobs: ~model, ~temperature,
       ~tts_policy / ~command_policy, ~max_pending_jobs. Defaults: TTS uses
       "fuzzy,lut,saved,generate"; commands use
       "generate,saved,fuzzy,lut". "fuzzy" queries the Chroma-backed
       performance fuzzy LUT index. -->
  <node name="face_animator" pkg="logos_hardware" type="face_animator_node.py" output="screen"/>

  <!-- Arm Animator: same pattern as the face animator, for the tiny
       fine-tuned arm model (see TINY_ARM_DEPLOYMENT.md). Sequencer falls
       back to the semantic arm LUT without it, so this node is safe to
       disable. Defaults match the face animator: TTS uses
       "fuzzy,lut,saved,generate"; commands use
       "generate,saved,fuzzy,lut". Tweakable via ~tts_policy /
       ~command_policy / ~max_pending_jobs, per-call "arm_policy", or
       command payload "policy". -->
  <node name="arm_animator" pkg="logos_hardware" type="arm_animator_node.py" output="screen"/>

</launch>
