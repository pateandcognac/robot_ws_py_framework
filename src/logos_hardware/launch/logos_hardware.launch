<launch>
  <!-- 
    LOGOS HARDWARE LAYER
    - Pan/Tilt (Arduino Mega)
    - Arms (Arduino Uno)
    - Arm Controllers
    - Idle State Monitor
    - Face (ASCII)
  -->

  <!-- 1. ARDUINO BRIDGES -->
  <!-- Pan-Tilt Control (Mega) -->
  <node name="pantilt_serial_node" pkg="rosserial_python" type="serial_node.py" output="screen">
    <param name="port" value="/dev/mega_duino"/> <!-- Updated to your udev rule -->
    <param name="baud" value="57600"/>
  </node>

  <!-- Arm Control (Uno) -->
  <!-- You used rosserial_server in the old file, but python in the other. 
       Let's stick to python for consistency unless you need C++ performance. -->
  <node name="arm_serial_node" pkg="rosserial_python" type="serial_node.py" output="screen">
    <param name="port" value="/dev/uno_duino"/> <!-- Updated to your udev rule -->
    <param name="baud" value="57600"/>
  </node>

  <!-- 2. EXPRESSIVE NODES (Python 3.8 System) -->
  
  <!-- Arm Logic -->
  <node name="arm_playback" pkg="logos_hardware" type="arm_playback_node.py" output="screen"/>
  <node name="arm_controller" pkg="logos_hardware" type="arm_controller_node.py" output="screen"/>
  
  <!-- State Monitor (Battery/Charging/Idle anims) -->
  <node name="idle_state_monitor" pkg="logos_hardware" type="idle_state_indicator.py" output="screen"/>

  <!-- 3. THE FACE (C++) -->
  <!-- Note: This outputs to the terminal where you launch it! -->
  <!-- We do not usually put this in a launch file if we want to see it, 
       but if you run this launch file in a dedicated terminal, it works. -->
  <!-- <node name="face_node" pkg="logos_face" type="face_node" output="screen"/> -->

  <!-- 4. AUDIO (Placeholder for Kokoro) -->
  <!-- We will add the Kokoro node here later -->

</launch>